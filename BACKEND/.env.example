# Environment variables for Campus Companion Robot
# Copy this file to .env and fill in values

# Server
NODE_ENV=development
PORT=5002
HOST=127.0.0.1
SESSION_SECRET=dev-secret
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:5000

# HTTPS (for local mic/camera over LAN). Set HOST=0.0.0.0 to expose LAN.
# Use mkcert to generate a trusted local certificate, then set:
# HTTPS=true
# SSL_KEY_FILE=C:\\Projects\\Campus-Companio\\.cert\\dev-key.pem
# SSL_CRT_FILE=C:\\Projects\\Campus-Companio\\.cert\\dev-cert.pem
# If HTTPS is false/empty, the server uses HTTP (mic/camera only allowed on localhost).
HTTPS=
SSL_KEY_FILE=
SSL_CRT_FILE=

# OpenRouter (LLM)
# REQUIRED: Obtain from https://openrouter.ai/
OPENROUTER_API_KEY="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"
# Optional model override
OPENROUTER_MODEL=openai/gpt-4o-mini
# Optional metadata
OPENROUTER_REFERER=
OPENROUTER_TITLE=Campus Companion

# Vision LLM model for DESCRIBE command (multimodal image description)
VISION_LLM_MODEL=google/gemma-3-27b-it:free

# Python Vision Server URL
VISION_SERVER_URL=http://localhost:8000

# Database (Drizzle / Postgres)
# REQUIRED for drizzle-kit and future persistence
DATABASE_URL=postgres://user:pass@host:5432/dbname

# Robot / ESP32 (future integration)
# High-level command endpoint(s); do NOT expose motor primitives directly
ESP32_URL=http://192.168.4.1/cmd
ROBOT_API_BASE_URL=http://esp32.local
ROBOT_WS_URL=ws://esp32.local:9001
ROBOT_AUTH_TOKEN=

# Vite / Replit optional
REPLIT_INTERNAL_APP_DOMAIN=
REPLIT_DEV_DOMAIN=
